{
  "name": "at-terminal",
  "description": "AT-Terminal — local-first desktop terminal and module workspace (Tauri v2).",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rushikeshvemuru/AT-Terminal.git"
  },
  "bugs": {
    "url": "https://github.com/rushikeshvemuru/AT-Terminal/issues"
  },
  "homepage": "https://github.com/rushikeshvemuru/AT-Terminal#readme",
  "keywords": [
    "tauri",
    "terminal",
    "ide",
    "modules",
    "tmux",
    "desktop",
    "local-first"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run generate-icons",
    "build": "tsc && vite build",
    "prepare-tauri-bundle": "npm run build && node scripts/prepare-tauri-bundle.mjs",
    "prelint": "npm run generate-icons",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e": "playwright test",
    "generate-icons": "node scripts/generate-icon-manifest.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-shell": "2.3.5",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.454.0",
    "material-icon-theme": "^5.35.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "tailwind-merge": "^2.5.4",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-serialize": "^0.11.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "2.11.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.0",
    "typescript-language-server": "^5.3.0",
    "vite": "^5.4.10"
  }
}
